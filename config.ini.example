[api]
active_provider = DeepSeek

[api.DeepSeek]
api_key = 
base_url = https://api.deepseek.com
model = deepseek-v4-flash

[api.Kimi (月之暗面)]
api_key = 
base_url = https://api.moonshot.cn/v1
model = moonshot-v1-32k

[api.OpenAI (官方)]
api_key = 
base_url = https://api.openai.com/v1
model = gpt-4o-mini

[api.SiliconFlow (硅基流动)]
api_key = 
base_url = https://api.siliconflow.cn/v1
model = deepseek-ai/DeepSeek-V3

[api.智谱 AI (BigModel)]
api_key = 
base_url = https://open.bigmodel.cn/api/paas/v4
model = glm-5

[api.通义千问 (DashScope)]
api_key = 
base_url = https://dashscope.aliyuncs.com/compatible-mode/v1
model = qwen-plus

[api.Grok (xAI)]
api_key = 
base_url = https://api.x.ai/v1
model = grok-4.20-reasoning

[api.Custom]
api_key = 
base_url = 
model = 

[translation]
model = deepseek-v4-flash
target_lang = Chinese
threads = 4

[display]
display_duration = 10
window_width = 800
window_height = 120

[transcription]
backend = whisper
whisper_model = base
funasr_model = iic/speech_paraformer-large_asr_nat-zh-cn-16k-common-vocab8404-pytorch
device = auto
compute_type = float16
source_language = auto
transcription_workers = 4

[audio]
device_index = auto
sample_rate = 16000
silence_threshold = 0.005
silence_duration = 0.5
chunk_duration = 0.1
max_phrase_duration = 30
streaming_mode = true
streaming_interval = 3
streaming_step_size = 0.2
update_interval = 0.8
streaming_overlap = 0.3

[updates]
repo = WZXsea/transworld
auto_check_updates = true
